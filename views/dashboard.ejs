<div class="flex items-end justify-between gap-4 mb-8">
  <div>
    <p class="text-xs uppercase tracking-[0.16em] text-tertiary mb-1">Signed in as <%= currentUser.username %></p>
    <h1 class="font-display text-5xl leading-[1.05] tracking-tight">Your board.</h1>
  </div>
  <a href="/topics/new" class="btn btn-primary">New topic</a>
</div>

<section class="mb-10">
  <div class="flex items-baseline justify-between mb-3">
    <h2 class="text-sm font-semibold uppercase tracking-[0.12em] text-tertiary">Subscribed</h2>
    <% if (subscribed.length > 0) { %>
      <span class="text-xs text-quaternary"><%= subscribed.length %> topic<%= subscribed.length === 1 ? '' : 's' %></span>
    <% } %>
  </div>

  <% if (subscribed.length === 0) { %>
    <div class="card card-body text-center">
      <p class="text-secondary">You haven't subscribed to anything yet.</p>
      <p class="text-sm text-tertiary mt-1">
        Pick one from below or <a href="/topics/new" class="link">start your own</a>.
      </p>
    </div>
  <% } else { %>
    <div class="flex flex-col gap-3">
      <% subscribed.forEach(function (t) { %>
        <div class="card">
          <div class="card-body">
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0 flex-1">
                <a href="/topics/<%= t._id %>" class="font-display text-2xl tracking-tight leading-snug text-balance hover:opacity-80 transition-opacity">
                  <%= t.title %>
                </a>
                <p class="text-xs text-tertiary mt-1">
                  by <%= t.author ? t.author.username : '(deleted)' %>
                  <span class="text-quaternary">·</span>
                  <span class="mono"><%= t.accessCount || 0 %></span>
                  view<%= (t.accessCount || 0) === 1 ? '' : 's' %>
                </p>
              </div>
              <form method="POST" action="/topics/<%= t._id %>/unsubscribe"
                    data-confirm="You'll stop getting notifications for &ldquo;<%= t.title %>&rdquo;."
                    data-confirm-title="Unsubscribe?"
                    data-confirm-label="Unsubscribe"
                    data-confirm-destructive="true">
                <button type="submit" class="btn btn-danger-ghost btn-xs">Unsubscribe</button>
              </form>
            </div>

            <% if (t.recentMessages && t.recentMessages.length > 0) { %>
              <div class="mt-3 hairline-top pt-3 flex flex-col gap-1.5">
                <% t.recentMessages.forEach(function (m) { %>
                  <div class="text-sm leading-snug">
                    <span class="font-medium"><%= m.author ? m.author.username : '(deleted)' %></span>
                    <span class="text-quaternary">·</span>
                    <span class="text-secondary"><%= m.text.length > 140 ? m.text.slice(0, 140) + '…' : m.text %></span>
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <p class="text-sm text-quaternary mt-2 italic">No messages yet.</p>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</section>

<section>
  <div class="flex items-baseline justify-between mb-3">
    <h2 class="text-sm font-semibold uppercase tracking-[0.12em] text-tertiary">Available</h2>
    <a href="/topics" class="text-xs link">Browse all →</a>
  </div>

  <% if (available.length === 0) { %>
    <div class="card card-body text-center text-tertiary">Nothing else right now.</div>
  <% } else { %>
    <div class="flex flex-col gap-2">
      <% available.forEach(function (t) { %>
        <div class="card">
          <div class="card-body-tight flex items-center justify-between gap-4">
            <div class="min-w-0 flex-1">
              <a href="/topics/<%= t._id %>" class="font-semibold hover:opacity-70 transition-opacity">
                <%= t.title %>
              </a>
              <p class="text-xs text-tertiary mt-0.5">
                by <%= t.author ? t.author.username : '(deleted)' %>
                <span class="text-quaternary">·</span>
                <%= (t.subscribers || []).length %>
                subscriber<%= (t.subscribers || []).length === 1 ? '' : 's' %>
                <span class="text-quaternary">·</span>
                <span class="mono"><%= t.accessCount || 0 %></span>
                view<%= (t.accessCount || 0) === 1 ? '' : 's' %>
              </p>
            </div>
            <form method="POST" action="/topics/<%= t._id %>/subscribe">
              <button type="submit" class="btn btn-secondary btn-sm">Subscribe</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</section>
