<div class="flex items-end justify-between mb-8 gap-4">
  <div>
    <p class="text-xs uppercase tracking-[0.16em] text-tertiary mb-1">All threads</p>
    <h1 class="font-display text-4xl sm:text-5xl tracking-tight leading-[1.05]">Topics.</h1>
  </div>
  <% if (currentUser) { %>
    <a href="/topics/new" class="btn btn-primary">New topic</a>
  <% } else { %>
    <a href="/register" class="btn btn-primary">Join to post</a>
  <% } %>
</div>

<% if (topics.length === 0) { %>
  <div class="card card-body text-center text-tertiary">
    No topics yet.
    <% if (currentUser) { %>
      <a href="/topics/new" class="link ml-1">Start the first one →</a>
    <% } %>
  </div>
<% } else { %>
  <div class="flex flex-col gap-2">
    <% topics.forEach(function (t) { %>
      <a href="/topics/<%= t._id %>" class="card card-body-tight reveal flex items-center justify-between gap-4">
        <div class="min-w-0 flex-1">
          <p class="font-display text-2xl tracking-tight leading-snug text-balance"><%= t.title %></p>
          <p class="text-xs text-tertiary mt-1">
            by <%= t.author ? t.author.username : '(deleted)' %>
            <span class="text-quaternary">·</span>
            <%= (t.subscribers || []).length %>
            subscriber<%= (t.subscribers || []).length === 1 ? '' : 's' %>
            <span class="text-quaternary">·</span>
            <span class="mono"><%= t.accessCount || 0 %></span>
            view<%= (t.accessCount || 0) === 1 ? '' : 's' %>
          </p>
        </div>
        <span class="arrow text-sm">→</span>
      </a>
    <% }) %>
  </div>
<% } %>
