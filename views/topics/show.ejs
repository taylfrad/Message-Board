<div class="mb-5">
  <a href="/topics" class="text-sm link">← Topics</a>
</div>

<header class="mb-8 flex items-start justify-between gap-4">
  <div class="min-w-0 flex-1">
    <h1 class="font-display text-4xl sm:text-5xl tracking-tight leading-[1.05] text-balance">
      <%= topic.title %>
    </h1>
    <p class="text-sm text-tertiary mt-2">
      by <span class="text-secondary"><%= topic.author ? topic.author.username : '(deleted)' %></span>
      <span class="text-quaternary">·</span>
      <%= topic.subscribers.length %>
      subscriber<%= topic.subscribers.length === 1 ? '' : 's' %>
      <span class="text-quaternary">·</span>
      <span class="mono"><%= topic.accessCount || 0 %></span>
      view<%= (topic.accessCount || 0) === 1 ? '' : 's' %>
      <span class="text-quaternary">·</span>
      <time class="ts"
            datetime="<%= new Date(topic.createdAt).toISOString() %>"><%= new Date(topic.createdAt).toISOString() %></time>
    </p>
  </div>
  <% if (currentUser) { %>
    <form method="POST"
          action="/topics/<%= topic._id %>/<%= isSubscribed ? 'unsubscribe' : 'subscribe' %>"
          <% if (isSubscribed) { %>
          data-confirm="You'll stop getting notifications for &ldquo;<%= topic.title %>&rdquo;."
          data-confirm-title="Unsubscribe?"
          data-confirm-label="Unsubscribe"
          data-confirm-destructive="true"
          <% } %>>
      <button type="submit" class="btn <%= isSubscribed ? 'btn-danger-ghost' : 'btn-primary' %> btn-sm">
        <%= isSubscribed ? 'Unsubscribe' : 'Subscribe' %>
      </button>
    </form>
  <% } %>
</header>

<% if (topic.body) { %>
  <div class="card card-body mb-6">
    <p class="whitespace-pre-wrap leading-relaxed text-secondary"><%= topic.body %></p>
  </div>
<% } %>

<%- include('../partials/flash') %>

<section class="mb-6">
  <h2 class="text-sm font-semibold uppercase tracking-[0.12em] text-tertiary mb-3">
    Messages
    <% if (messages.length > 0) { %>
      <span class="text-quaternary font-normal normal-case tracking-normal ml-1">· <%= messages.length %></span>
    <% } %>
  </h2>

  <% if (messages.length === 0) { %>
    <p class="text-tertiary text-sm italic">No messages yet.</p>
  <% } else { %>
    <div class="flex flex-col gap-2">
      <% messages.forEach(function (m) { %>
        <div class="card card-body-tight fade-scroll">
          <div class="flex items-baseline justify-between gap-2 mb-1">
            <span class="font-semibold text-sm"><%= m.author ? m.author.username : '(deleted)' %></span>
            <time class="ts text-xs text-quaternary"
                  datetime="<%= new Date(m.createdAt).toISOString() %>"><%= new Date(m.createdAt).toISOString() %></time>
          </div>
          <p class="whitespace-pre-wrap text-secondary leading-relaxed"><%= m.text %></p>
        </div>
      <% }) %>
    </div>
  <% } %>
</section>

<% if (currentUser && isSubscribed) { %>
  <form method="POST" action="/topics/<%= topic._id %>/messages" class="flex flex-col gap-2">
    <textarea name="text" required maxlength="2000" rows="3" class="textarea"
              placeholder="Add to the thread..."><%= values.text || '' %></textarea>
    <div class="flex justify-end">
      <button type="submit" class="btn btn-primary">Post</button>
    </div>
  </form>
<% } else if (currentUser) { %>
  <div class="alert alert-info">Subscribe to this topic to post a message.</div>
<% } else { %>
  <div class="alert alert-info">
    <a href="/login" class="link">Sign in</a> to subscribe and post.
  </div>
<% } %>
