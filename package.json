{
  "name": "message-board",
  "version": "1.0.0",
  "description": "Message board service with MVC, Observer, and Singleton patterns",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node scripts/seed.js",
    "build:css": "tailwindcss -i ./src/tailwind.css -o ./public/css/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./src/tailwind.css -o ./public/css/tailwind.css --watch",
    "postinstall": "tailwindcss -i ./src/tailwind.css -o ./public/css/tailwind.css --minify"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "Taylor Fradella",
  "license": "MIT",
  "private": true,
  "dependencies": {
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "connect-mongo": "^6.0.0",
    "dotenv": "^17.4.2",
    "ejs": "^5.0.2",
    "express": "^5.2.1",
    "express-ejs-layouts": "^2.5.1",
    "express-session": "^1.19.0",
    "mongodb": "^7.2.0",
    "mongoose": "^9.5.0",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "playwright": "^1.59.1"
  }
}
