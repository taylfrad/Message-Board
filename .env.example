# Full MongoDB Atlas connection string. Include the database name at the end.
# Example: mongodb+srv://user:pass@cluster0.abc123.mongodb.net/messageboard?retryWrites=true
MONGODB_URI=

# Random string used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=

# Optional. Defaults to 3000. Render sets this automatically in production.
PORT=3000
